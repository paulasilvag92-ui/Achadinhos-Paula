# Banco de dados PostgreSQL (Neon ou Supabase)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Chave secreta para JWT (gere uma string aleatória segura)
JWT_SECRET="sua_chave_secreta_muito_segura_aqui_min_32_chars"

# URL pública do site (usado para SEO/OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Credenciais do Admin (login simples via env vars)
ADMIN_EMAIL="admin@admin.com"
ADMIN_PASSWORD="admin"
